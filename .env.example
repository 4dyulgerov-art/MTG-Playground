# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Find these in Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE

# v7.6.3 — optional WebSocket relay URL.
# When set, the client uses your custom Bun WS server (see server/ folder)
# as the realtime transport instead of Supabase Realtime broadcasts.
# Leave commented to fall back to Supabase Realtime. Phase 2a optimizations
# (slim payloads, drag gating, throttle, interpolation) work in either mode.
#
# Format: wss://your-relay.fly.dev    (production)
#         ws://localhost:3001         (local dev)
#
# VITE_WS_URL=wss://YOUR-RELAY.fly.dev
